# Copy this file to ".env" and fill in your values. NEVER commit .env.
# Get a free Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Groq production models (verified at https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile        # main reasoning / agent model
GROQ_MODEL_FAST=llama-3.1-8b-instant      # fast, cheap, light calls
LLM_TEMPERATURE=0.2

# Domain assumptions (editable; India context)
GRID_IMPORT_PRICE=8.0      # Rs/kWh at peak
CO2_PER_KWH_GRID=0.82      # kg CO2 per kWh of grid electricity
